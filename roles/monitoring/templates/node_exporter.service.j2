[Unit]
Description=NodeExporter
# Binds to the Tailscale IP on most nodes — wait for the network to be up.
Wants=network-online.target
After=network-online.target

[Service]
TimeoutStartSec=0
User=node_exporter
ExecStart={{ node_exporter_bin_path }} --web.listen-address={{ node_exporter_listen_address }}:{{ node_exporter_port }} {{ node_exporter_options }}
Restart={{ node_exporter_restart }}

[Install]
WantedBy=multi-user.target