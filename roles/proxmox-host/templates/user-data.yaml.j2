#cloud-config

# OS keyboard layout (separate from the Proxmox VNC console keyboard)
# 'be' = Belgian AZERTY (XKB layout code, different from Proxmox's 'fr-be')
keyboard:
  layout: {{ cloud_init_keyboard_layout }}

runcmd:
  # Empty the cloud-init SSH drop-in so it doesn't interfere with opkssh
  # The security role manages sshd_config directly via sshd_config.d/
  - truncate -s 0 /etc/ssh/sshd_config.d/50-cloud-init.conf
  - systemctl reload ssh
